NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"
# Server-only. BIP39 mnemonic whose derived pubkey (BIP84 m/84'/0'/0'/0/0) is treated as the
# platform admin. Omit or leave empty to disable admin entirely (no one will be admin).
# Replace with a real, secret mnemonic before deploying. The placeholder below is public.
ADMIN_MNEMONIC="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"
# Server-only. The admin's BIP39 passphrase ("13th word"). MUST equal the passphrase the admin
# uses in the UI when creating/restoring their account, otherwise the derived pubkey won't match
# and no one gets isAdmin. Leave empty only if the admin account uses no passphrase.
# NOTE: this same identity also decrypts dispute chat history (parties re-encrypt message CEKs
# toward the admin pubkey on dispute open). Rotating it forgoes access to chats re-encrypted
# toward the old admin pubkey.
ADMIN_PASSPHRASE=""

# Platform fee: percentage surcharge added on top of each order, paid by the buyer (default: 1).
# The buyer funds `goods + fee`, the seller nets the goods price, the admin keeps the fee. The fee is
# `operatorDust + ceil(total * percent / 100)`: the dust base keeps the fee output above the
# operator's dust threshold (it becomes its own settlement output) while the platform nets the full
# percentage on top. Set "0" to disable. Example: "2" = 2%.
PLATFORM_FEE_PERCENT="1"
# Admin dispute share: additional percentage taken when admin resolves a dispute (default: 0).
# Only applied during dispute conclusion, on top of the platform fee. Example: "5" = 5%.
ADMIN_DISPUTE_SHARE_PERCENT="0"

# Server-only. 32-byte key, base64-encoded, used to encrypt Key.code at rest (AES-256-GCM)
# and to derive the HMAC used for code deduplication. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this value requires re-encrypting existing rows (the v1: prefix reserves room for
# a future versioned rotation). Losing it makes all stored key codes unrecoverable.
ENCRYPTION_KEY="change-me-32-byte-base64"

# Required — no SQLite fallback. Start the container: docker compose up -d postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/antigone"

# Optional TLS for a remote Postgres. Set DATABASE_CA_CERT to a PEM CA file path to encrypt
# and verify the server certificate (verify-full by default, read in src/db/index.ts).
# Set DATABASE_SSL_NO_VERIFY=true for verify-ca (encrypt + trust CA, skip hostname/chain check)
# when the server cert's CN/SAN doesn't include the host. Leave both unset for local plaintext.
# DATABASE_CA_CERT="/abs/path/to/ca-certificate.crt"
# DATABASE_SSL_NO_VERIFY="false"

# Arkade operator (client + server). Must be the mutinynet (signet) server so the wallet's on-chain
# network is tb1… and matches the escrow derivation. If unset, the SDK defaults to
# https://arkade.computer (mainnet → bc1… addresses).
NEXT_PUBLIC_ARK_OPERATOR_URL="https://mutinynet.arkade.sh"

# S3-compatible storage (MinIO) for chat attachments (immagini delle prove nelle dispute).
# The client endpoint is built as `${MINIO_USE_SSL ? https : http}://${MINIO_ENDPOINT}:${MINIO_PORT}`.
# Local dev (docker compose): localhost:9000 + USE_SSL=false.
# TLS-fronted MinIO (reverse proxy): set USE_SSL=true and MINIO_PORT to the TLS port (es. 443),
# altrimenti il browser riceve ERR_SSL_PROTOCOL_ERROR sui presigned URL.
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="antigone-dev"
MINIO_REGION="us-east-1"
MINIO_USE_SSL="false"
# Public base URL for MinIO bucket (used by product-image proxy to strip full URLs to keys)
NEXT_PUBLIC_MINIO_URL="http://localhost:9000/antigone-dev"
