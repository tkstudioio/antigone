# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
.idea/
*.pem
sqlite.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local settings
.claude/settings.local.json

# obsidian mcp (contains personal API key)
.mcp.json

# internal planning artifacts — never versioned (synced into docs/ before deletion)
.claude/tasks/
docs/superpowers/

*.crt
*storybook.log
storybook-static
